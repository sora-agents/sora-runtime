# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/

# Virtual environments
.venv/
venv/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Type checking / linting caches
.mypy_cache/
.ruff_cache/
.dmypy.json

# S-ORA runtime state (e.g. file-backed semantic/procedural/episodic memory stores) —
