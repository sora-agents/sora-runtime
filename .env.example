# Copy this file to `.env` and fill in your values.
#
# `.env` is gitignored and loaded automatically when present (see `build_agent` in sora/bootstrap.py).
# Real environment variables take precedence — a value here is only used when the variable is not
# already set. Never commit real secrets; keep them in `.env` (ignored) or a secrets manager.

# Anthropic API key for the default model-backed Reason strategy (requires the `[llm]` extra).
# Get one at https://console.anthropic.com/ — or run `ant auth login` instead of setting a key here.
ANTHROPIC_API_KEY=sk-ant-...
